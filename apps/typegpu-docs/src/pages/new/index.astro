---
import { Image } from 'astro:assets';
import GithubIconSvg from '../../assets/github-icon.svg';
import GithubIconDarkSvg from '../../assets/github-icon-dark.svg';
import SwmLogomarkSvg from '../../assets/swm-logomark.svg';
import SwmLogoSvg from '../../assets/typegpu-logo-light.svg';
import TypeGPULogoDark from '../../assets/typegpu-logo-dark.svg';
import TypeGPULogoLight from '../../assets/typegpu-logomark-light.svg';
import Backlog from '../../components/Backlog.astro';
import CodeShowcase from '../../components/CodeShowcase.astro';
import GetStartedButton from '../../components/GetStartedButton.astro';
import GradientTitle from '../../components/GradientTitle.astro';
import ThemeSwitcher from '../../components/ThemeSwitcher.astro';
import Videos from '../../components/Videos.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import LandingExampleGrid from '../../components/landing-examples/LandingExampleGrid';
import { HeroEffect } from '../../components/hero-effect/HeroEffect';
---

<PageLayout title="TypeGPU – Type-safe WebGPU toolkit">
  <div
    class="flex flex-col gap-14 text-blue-950 transition-colors duration-300 md:gap-30 dark:text-gray-100"
  >
    <main>
      <div class="absolute top-0 right-32 -z-10 flex flex-col items-center">
        <HeroEffect client:only="react" />
      </div>
      <header
        class="flex h-24 shrink-0 items-center justify-between self-stretch px-4 sm:px-7.5 md:px-10 lg:px-12.5"
      >
        <a href="https://swmansion.com" target="_blank" rel="noreferrer">
          <Image
            src={TypeGPULogoLight}
            class="block h-14 w-auto md:hidden"
            alt="Software Mansion Logo"
          />
          <Image
            src={TypeGPULogoDark}
            class="hidden h-14 w-auto md:dark:block"
            alt="Software Mansion Logo"
          />
          <Image
            src={SwmLogoSvg}
            class="hidden h-14 w-auto md:block md:dark:hidden"
            alt="Software Mansion Logo (mobile)"
          />
        </a>

        <div
          class="flex h-4 items-center gap-10 text-blue-900 dark:text-gray-100"
        >
          <!-- Light / Dark -->
          <ThemeSwitcher />
          <!-- Docs -->
          <a
            href="/TypeGPU/getting-started"
            target="_blank"
            class="no-underline"
            rel="noreferrer"
          >
            <p class="text-blue-900 dark:text-gray-100">Docs</p>
          </a>
          <!-- GitHub -->
          <a
            href="https://github.com/software-mansion/TypeGPU"
            target="_blank"
            rel="noreferrer"
          >
            <Image
              src={GithubIconSvg}
              class="h-6 w-6 fill-blue-900 opacity-75 sm:h-8 sm:w-8 md:h-10 md:w-10 dark:hidden"
              alt="GitHub Logo"
            />
            <Image
              src={GithubIconDarkSvg}
              class="hidden h-6 w-6 fill-gray-100 opacity-75 sm:h-8 sm:w-8 md:h-10 md:w-10 dark:block"
              alt="GitHub Logo"
            />
          </a>
        </div>
      </header>
    </main>

    <!-- Hero Section -->
    <section
      class="mx-auto flex flex-col items-center md:max-w-214 lg:max-w-[1024px] lg:px-72"
    >
      <div class="flex flex-col gap-4 px-6 md:gap-12 lg:px-0">
        <div
          class="text-2xl font-bold text-[#001A72] md:text-6xl dark:text-gray-100"
        >
          Type<GradientTitle title="GPU" />
        </div>
        <div
          class="text-2xl text-pretty text-blue-950 md:pr-40 md:text-3xl dark:text-gray-200"
        >
          A modular and open-ended toolkit for WebGPU, with advanced type
          interface and ability to write shaders in TypeScript.
        </div>
        <div class="my-4 flex flex-col gap-4 sm:flex-row md:my-8">
          <GetStartedButton class="h-18" />
          <a
            class="from-gradient-blue via-gradient-purple w-full bg-gradient-to-tl to-[#f8f7dd] bg-size-[200%_200%] bg-position-[100%_100%] p-[1px] no-underline sm:w-auto"
            href="/TypeGPU/examples"
          >
            <span
              class="box-border flex items-center justify-center bg-white px-6 py-4 text-center text-base text-black/75 shadow hover:text-black sm:py-6 md:px-7 md:text-xl lg:px-8 lg:py-5 lg:text-2xl dark:bg-gray-800 dark:text-gray-100 dark:hover:text-white"
            >
              See examples
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Code Showcase -->
    <section
      class="flex flex-col gap-10 px-6 sm:mx-auto md:max-w-214 md:gap-20 lg:max-w-[1024px]"
    >
      <div class="flex flex-col gap-4 md:gap-6">
        <h2
          class="center text-2xl font-medium text-blue-950 md:text-4xl dark:text-gray-100"
        >
          Ways to use TypeGPU
        </h2>
        <p
          class="text-lg text-pretty text-blue-950 md:text-xl dark:text-gray-300"
        >
          TypeGPU is a three-way toolkit that is easy for you to integrate
          granularly and doesn't restrict you in what you can do.
        </p>
      </div>
      <CodeShowcase />
      <div class="flex flex-col gap-6 md:flex-row md:justify-between md:gap-0">
        <h3
          class="center text-xl font-medium text-blue-950 md:text-2xl dark:text-gray-100"
        >
          Read more about TypeGPU
        </h3>
        <a
          class="from-gradient-blue via-gradient-purple w-full bg-gradient-to-tl to-[#f8f7dd] bg-size-[200%_200%] bg-position-[100%_100%] p-[1px] no-underline sm:w-auto"
          href="/TypeGPU/blog"
        >
          <span
            class="box-border flex items-center justify-center bg-white px-4 py-2 text-center text-base text-blue-950/75 shadow hover:text-black md:px-5 md:py-3 md:text-xl lg:px-6 lg:py-4 lg:text-2xl dark:bg-gray-800 dark:text-gray-100 dark:hover:text-white"
          >
            See blog post &#8594;
          </span>
        </a>
      </div>
    </section>

    <!-- TypeGPU examples -->
    <section class="mx-auto px-6 md:max-w-214 lg:max-w-[1024px] lg:px-72">
      <div class="flex flex-col gap-6 pb-14">
        <h2
          class="center text-2xl font-medium text-blue-950 md:text-4xl dark:text-gray-100"
        >
          Explore TypeGPU examples
        </h2>
        <p
          class="text-lg text-pretty text-blue-950 md:text-xl dark:text-gray-300"
        >
          From interactive 3D apps to custom shaders and type-safe libraries,
          TypeGPU gives you the tools to build anything WebGPU can do.
        </p>
      </div>
      <LandingExampleGrid client:visible />
    </section>

    <!-- Videos -->
    <section class="mx-auto px-6 md:max-w-214 lg:max-w-[1024px] lg:px-72">
      <div class="flex flex-col gap-6 pb-20">
        <h2
          class="center text-2xl font-medium text-blue-950 md:text-4xl dark:text-gray-100"
        >
          Get to know TypeGPU
        </h2>
        <p
          class="text-lg text-pretty text-blue-950 md:text-xl dark:text-gray-100"
        >
          Dive into guides, tutorials, and videos to see how TypeGPU can change
          the way you work with GPU rendering and computing.
        </p>
      </div>
      <Videos />
    </section>

    <!-- Backlog -->
    <section class="mx-auto my-12 px-6 md:max-w-214 lg:max-w-[1024px] lg:px-72">
      <div class="flex flex-col gap-6 pb-20">
        <h2
          class="center text-2xl font-medium text-blue-950 md:text-4xl dark:text-gray-100"
        >
          What's around the corner?
        </h2>
        <p
          class="text-lg text-pretty text-blue-950 md:text-xl dark:text-gray-300"
        >
          Our journey toward end-to-end type safety involves several
          interoperating primitives – explore our live board to see what
          features are coming next.
        </p>
      </div>
      <Backlog />
    </section>

    <!-- Call to Action -->
    <section
      class="mx-auto flex flex-col items-center gap-16 px-6 md:max-w-214 lg:max-w-[1024px] lg:px-72"
    >
      <h2
        class="text-center text-3xl leading-tight font-bold text-blue-950 lg:text-5xl dark:text-gray-100"
      >
        Ready to try out <span class="whitespace-nowrap"
          ><GradientTitle title="TypeGPU" />?</span
        >
      </h2>
      <GetStartedButton />
    </section>

    <!-- Footer -->
    <footer
      class="to-accent-50 mt-20 flex flex-col items-center gap-10 bg-gradient-to-b from-white md:gap-15 lg:gap-20 dark:from-[#232736] dark:to-gray-800"
    >
      <div
        class="mx-auto flex flex-col items-center gap-12 px-6 text-blue-950 md:max-w-214 lg:max-w-[1024px] lg:px-72 dark:text-gray-100"
      >
        <h2 class="text-center text-3xl leading-tight font-bold lg:text-5xl">
          We are <GradientTitle title="Software Mansion" />
        </h2>
        <div
          class="mb-4 text-center text-xl text-pretty text-blue-900 dark:text-gray-300"
        >
          We’re a software company built around improving developer experience
          and bringing to life the innovative ideas of our clients. Do you have
          a software project that we can help you with?
        </div>
        <GetStartedButton
          title="Hire us"
          href="https://swmansion.com/contact/projects?utm_source=typegpu&utm_medium=docs"
        />

        <div
          class="grid w-full max-w-7xl grid-cols-1 gap-8 bg-white py-8 text-center sm:grid-cols-2 md:grid-cols-3 dark:bg-[#272B3C]"
        >
          <a
            href="https://docs.swmansion.com/react-native-reanimated/"
            class="hover:text-accent-700 dark:hover:text-accent-200 text-blue-950 no-underline transition-colors dark:text-gray-100"
            >React Native Reanimated</a
          >
          <a
            href="https://docs.swmansion.com/react-native-gesture-handler/"
            class="hover:text-accent-700 dark:hover:text-accent-200 text-blue-950 no-underline transition-colors dark:text-gray-100"
            >React Native Gesture Handler</a
          >
          <a
            href="https://docs.swmansion.com/react-native-screens/"
            class="hover:text-accent-700 dark:hover:text-accent-200 text-blue-950 no-underline transition-colors dark:text-gray-100"
            >React Native Screens</a
          >
          <a
            href="https://github.com/software-mansion/react-native-svg"
            class="hover:text-accent-700 dark:hover:text-accent-200 text-blue-950 no-underline transition-colors dark:text-gray-100"
            >React Native SVG</a
          >
          <a
            href="https://docs.swmansion.com/react-native-audio-api/"
            class="hover:text-accent-700 dark:hover:text-accent-200 text-blue-950 no-underline transition-colors dark:text-gray-100"
            >React Native Audio API</a
          >
          <a
            href="https://docs.swmansion.com/react-native-executorch/"
            class="hover:text-accent-700 dark:hover:text-accent-200 text-blue-950 no-underline transition-colors dark:text-gray-100"
            >React Native ExecuTorch</a
          >
          <a
            href="https://docs.swmansion.com/TypeGPU/"
            class="hover:text-accent-700 dark:hover:text-accent-200 text-blue-950 no-underline transition-colors dark:text-gray-100"
            >TypeGPU</a
          >
          <a
            href="https://ide.swmansion.com/"
            class="hover:text-accent-700 dark:hover:text-accent-200 text-blue-950 no-underline transition-colors dark:text-gray-100"
            >Radon IDE</a
          >
          <a
            href="https://docs.swmansion.com/byegl/"
            class="hover:text-accent-700 dark:hover:text-accent-200 text-blue-950 no-underline transition-colors dark:text-gray-100"
            >byegl</a
          >
        </div>
        <div
          class="text-grayscale-100 flex flex-col items-center gap-4 pb-4 dark:text-gray-400"
        >
          &copy; Software Mansion {new Date().getFullYear()}. All trademarks and
          copyrights belong to their respective owners.

          <Image src={SwmLogomarkSvg} alt="Software Mansion Logomark" />
        </div>
      </div>
    </footer>
  </div>
</PageLayout>
