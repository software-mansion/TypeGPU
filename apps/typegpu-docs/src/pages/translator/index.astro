---
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import TranslatorApp from '../../components/translator/TranslatorApp';
import TypeGPULogoDark from '../../assets/typegpu-logo-dark.svg';
---

<PageLayout title="WGSL Translator | TypeGPU" forceTheme="dark">
  <main class="flex h-screen flex-col overflow-hidden">
    <h1 class="flex min-w-2xs items-center justify-center p-1">
      <a href="/TypeGPU">
        <Image src={TypeGPULogoDark} alt="TypeGPU Logo" class="relative w-40" />
      </a>
      <p class="font-sans text-lg text-gray-300">— translator</p>
    </h1>

    <TranslatorApp client:only="react" />
  </main>
</PageLayout>
