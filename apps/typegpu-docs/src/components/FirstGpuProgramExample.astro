---
import { Code } from "@astrojs/starlight/components";
import FirstGpuProgramRunnable, {
  FIRST_GPU_PROGRAM_SNIPPETS,
  type FirstGpuProgramExampleKey,
} from "./FirstGpuProgramExample.tsx";

interface Props {
  example: FirstGpuProgramExampleKey;
}

const { example } = Astro.props as Props;
const code = FIRST_GPU_PROGRAM_SNIPPETS[example];
---

<FirstGpuProgramRunnable client:load example={example}>
  <Code code={code} lang="ts" meta="twoslash {5, 15}" />
</FirstGpuProgramRunnable>
